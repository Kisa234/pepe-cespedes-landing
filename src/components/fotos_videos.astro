---

<section id="videos" class="bg-[#0D0D0D] py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10">
            <p class="text-xs uppercase tracking-[0.3em] text-white/40">
                Videos / Fotos
            </p>
            <h2 class="mt-2 font-serif text-3xl sm:text-4xl">
                Universo visual
            </h2>
        </div>

        <div class="grid grid-cols-1 gap-4 auto-rows-[220px] md:grid-cols-3">
            {
                mediaItems.map((item, index) => (
                    <article
                        class={`media-item group relative overflow-hidden bg-black ${spanClasses[item.span]} ${
                            index >= 4 ? "hidden md:block" : ""
                        }`}
                    >
                        {item.type === "image" ? (
                            <img
                                src={item.src}
                                alt=""
                                class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy"
                            />
                        ) : (
                            <button
                                class="relative h-full w-full"
                                data-video-url={item.url}
                            >
                                <img
                                    src={thumb(item.url)}
                                    alt={item.title}
                                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy"
                                />

                                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition" />

                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="h-14 w-14 flex items-center justify-center rounded-full border border-white/60 bg-black/40">
                                        ▶
                                    </div>
                                </div>

                                <div class="absolute bottom-0 left-0 p-4">
                                    <p class="text-sm text-white">
                                        {item.title}
                                    </p>
                                </div>
                            </button>
                        )}
                    </article>
                ))
            }
        </div>
        <div class="mt-10 flex justify-center md:hidden">
            <button
                id="show-more-btn"
                class="border border-white px-6 py-3 text-xs uppercase tracking-[0.25em] text-white transition hover:bg-white hover:text-black"
            >
                Ver más
            </button>
        </div>
    </div>
</section>


<script>
    const showMoreBtn = document.getElementById("show-more-btn");

    showMoreBtn?.addEventListener("click", () => {
        document.querySelectorAll(".media-item").forEach((el) => {
            el.classList.remove("hidden");
        });

        showMoreBtn.remove(); // desaparece el botón
    });
</script>