---
---

<section id="contacto" class="bg-black py-20 sm:py-28 overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="grid gap-0 lg:grid-cols-2">

            <!-- IMAGEN -->
            <div class="relative order-2 lg:order-1">
                <div class="h-80 lg:h-full min-h-120 overflow-hidden">
                    <img
                        src="/images/PPa9.webp"
                        alt="Pepe Céspedes"
                        class="h-full w-full object-cover object-top"
                    />
                    <div class="absolute inset-0 bg-linear-to-r from-transparent via-transparent to-black hidden lg:block" />
                    <div class="absolute inset-0 bg-linear-to-t from-black via-black/20 to-transparent lg:hidden" />
                </div>
            </div>

            <!-- CONTENIDO -->
            <div class="order-1 lg:order-2 flex flex-col justify-center lg:pl-16">
                <div class="mb-10">
                    <p class="text-xs uppercase tracking-[0.3em] text-white/40">
                        Contacto
                    </p>
                    <h2 class="mt-2 font-serif text-3xl sm:text-4xl">
                        Hablemos
                    </h2>
                    <p class="mt-4 max-w-md text-white/60 leading-relaxed">
                        Para conciertos, colaboraciones, prensa o cualquier consulta,
                        no dudes en escribir o llamar.
                    </p>
                </div>

                <div class="space-y-6">

                    <!-- Email -->
                    <a
                        href="mailto:contacto@pepecespedes.com"
                        class="group flex items-start gap-5 border-t border-white/10 pt-6"
                    >
                        <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center border border-white/15">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-[11px] uppercase tracking-[0.2em] text-white/30 mb-1">Correo</p>
                            <p class="font-serif text-lg text-white transition group-hover:text-white/70">
                                contacto@pepecespedes.com
                            </p>
                        </div>
                    </a>

                    <!-- Teléfono -->
                    <a
                        href="tel:+51987654321"
                        class="group flex items-start gap-5 border-t border-white/10 pt-6"
                    >
                        <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center border border-white/15">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-[11px] uppercase tracking-[0.2em] text-white/30 mb-1">Teléfono</p>
                            <p class="font-serif text-lg text-white transition group-hover:text-white/70">
                                +51 987 654 321
                            </p>
                        </div>
                    </a>

                    <!-- Línea final -->
                    <div class="border-t border-white/10 pt-6">
                        <p class="text-xs text-white/30 leading-relaxed">
                            Respuestas en un plazo de 24–48 horas hábiles.
                        </p>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>