];

const getYoutubeId = (url: string) => {
    const match = url.match(/(?:youtu\.be\/|v=)([^&?]+)/);
    return match ? match[1] : "";
};

const thumb = (url: string) => {
    const id = getYoutubeId(url);
    return `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
};
---

<section id="colaboraciones" class="bg-black py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12">
            <p class="text-xs uppercase tracking-[0.3em] text-white/40">
                Colaboraciones
            </p>
            <h2 class="mt-2 font-serif text-3xl sm:text-4xl">
                Junto a otros artistas
            </h2>
            <p class="mt-4 max-w-2xl text-white/60">
                Encuentros musicales que dejaron huella.
            </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
                colaboraciones.map((item) => {
                    const id = getYoutubeId(item.videoUrl);
                    const embedSrc = `https://www.youtube.com/embed/${id}`;
                    return (
                        <button
                            class="colab-card group relative overflow-hidden bg-[#111] text-left"
                            data-embed={embedSrc}
                            data-titulo={item.titulo}
                            data-artista={item.artista}
                        >
                            {/* Thumbnail */}
                            <div class="relative aspect-video w-full overflow-hidden">
                                <img
                                    src={thumb(item.videoUrl)}
                                    alt={item.titulo} loading="lazy"
                                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                                />
                                <div class="absolute inset-0 bg-black/30 transition duration-300 group-hover:bg-black/50" />

                                {/* Play button */}
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="h-12 w-12 flex items-center justify-center rounded-full border border-white/60 bg-black/40 transition duration-300 group-hover:scale-110">
                                        ▶
                                    </div>
                                </div>
                            </div>

                            {/* Info */}
                            <div class="p-5 border-t border-white/8">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-white/40 mb-1">
                                    {item.artista}
                                </p>
                                <p class="font-serif text-lg text-white leading-snug">
                                    {item.titulo}
                                </p>
                            </div>
                        </button>
                    );
                })
            }
        </div>
    </div>
</section>

<!-- MODAL (reutiliza el mismo estilo que fotos_videos) -->
<div
    id="colab-modal"
    class="fixed inset-0 hidden items-center justify-center bg-black/90 z-50"
>
    <div class="relative w-full max-w-5xl p-4">
        <button
            id="colab-close"
            class="absolute -top-8 right-4 text-white/70 hover:text-white text-2xl transition"
        >✕</button>

        <p id="colab-modal-artista" class="mb-1 text-[11px] uppercase tracking-[0.25em] text-white/50"></p>
        <p id="colab-modal-titulo" class="mb-3 font-serif text-xl text-white"></p>

        <div class="aspect-video">
            <iframe
                id="colab-frame"
                class="w-full h-full"
                src=""
                allow="autoplay"
                allowfullscreen
            ></iframe>
        </div>
    </div>
</div>

<script>
    const cards = document.querySelectorAll(".colab-card");
    const modal = document.getElementById("colab-modal");
    const frame = document.getElementById("colab-frame") as HTMLIFrameElement;
    const closeBtn = document.getElementById("colab-close");
    const modalTitulo = document.getElementById("colab-modal-titulo");
    const modalArtista = document.getElementById("colab-modal-artista");

    const openModal = (embed: string, titulo: string, artista: string) => {
        if (!modal || !frame) return;
        frame.src = `${embed}?autoplay=1`;
        if (modalTitulo) modalTitulo.textContent = titulo;
        if (modalArtista) modalArtista.textContent = artista;
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
        if (!modal || !frame) return;
        frame.src = "";
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        document.body.style.overflow = "";
    };

    cards.forEach((card) => {
        card.addEventListener("click", () => {
            const embed = card.getAttribute("data-embed") ?? "";
            const titulo = card.getAttribute("data-titulo") ?? "";
            const artista = card.getAttribute("data-artista") ?? "";
            openModal(embed, titulo, artista);
        });
    });

    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });
</script>
