    // Agrega más colaboraciones aquí
];

const getYoutubeId = (url: string) => {
    const match = url.match(/(?:youtu\.be\/|v=)([^&?]+)/);
    return match ? match[1] : "";
};

const thumb = (url: string) => {
    const id = getYoutubeId(url);
    return `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
};
---

<section id="colaboraciones" class="bg-black py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12">
            <p class="text-xs uppercase tracking-[0.3em] text-white/40">
                Colaboraciones
            </p>
            <h2 class="mt-2 font-serif text-3xl sm:text-4xl">
                Junto a otros artistas
            </h2>
            <p class="mt-4 max-w-2xl text-white/60">
                Encuentros musicales que dejaron huella.
            </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
                colaboraciones.map((item) => {
                    const id = getYoutubeId(item.videoUrl);
                    const embedSrc = `https://www.youtube.com/embed/${id}`;
                    return (
                        <button
                            class="colab-card group relative overflow-hidden bg-[#111] text-left"
                            data-embed={embedSrc}
                            data-titulo={item.titulo}
                            data-artista={item.artista}
                        >
                            {/* Thumbnail */}
                            <div class="relative aspect-video w-full overflow-hidden">
                                <img
                                    src={thumb(item.videoUrl)}
                                    alt={item.titulo} loading="lazy"
                                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                                />
                                <div class="absolute inset-0 bg-black/30 transition duration-300 group-hover:bg-black/50" />

                                {/* Play button */}
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="h-12 w-12 flex items-center justify-center rounded-full border border-white/60 bg-black/40 transition duration-300 group-hover:scale-110">
                                        ▶
                                    </div>
                                </div>
                            </div>

                            {/* Info */}
                            <div class="p-5 border-t border-white/8">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-white/40 mb-1">
                                    {item.artista}
                                </p>
                                <p class="font-serif text-lg text-white leading-snug">
                                    {item.titulo}
                                </p>
                            </div>
                        </button>
                    );
                })
            }
        </div>
    </div>
</section>