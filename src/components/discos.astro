    { title: "Rumbo al río en mototaxi", spotifyUrl: "https://open.spotify.com/intl-es/album/64qCnYaLoqGarXPFyTy0S7?si=PPK__uPXTB2MuOiz7Pp42A", image: "/images/discos/Rumbo-al-río-en-mototaxi-2000px-_1_.webp" },
